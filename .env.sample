# Notion API Token (get from https://www.notion.so/my-integrations)
NOTION_TOKEN=ntn_your_token_here

# Notion Database IDs
NOTION_DB_APPLICATIONS=your-applications-db-id
NOTION_DB_COMPANIES=your-companies-db-id
NOTION_DB_CONNECTIONS=your-connections-db-id

# Notion Page IDs (project detail pages)
NOTION_PAGE_ROMA=your-roma-page-id
NOTION_PAGE_MROMA=your-mroma-page-id
NOTION_PAGE_SERA=your-sera-page-id
NOTION_PAGE_DEEP_RESEARCH=your-deep-research-page-id
NOTION_PAGE_TXT2SQL=your-txt2sql-page-id
NOTION_PAGE_HARNESS=your-harness-page-id

# Notion Page IDs (profile/resume/projects)
NOTION_PAGE_PROFILE=your-preferences-page-id
NOTION_PAGE_PROJECTS=your-projects-summary-page-id
NOTION_PAGE_RESUME=your-resume-page-id
NOTION_PAGE_PARENT=your-parent-projects-page-id
